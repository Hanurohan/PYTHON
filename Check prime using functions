def is_prime(n):
    if n < 2:
        print("Please enter a number greater than 1")
        return

    for i in range(2, n):
        if n % i == 0:
            print('Not a Prime Number')
            return  
    print('Prime Number')


is_prime(5)
is_prime(6)
is_prime(1)
is_prime(99)
is_prime(101)
